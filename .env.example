# Upstash Redis (via Vercel Integration)
# These are auto-populated when you connect Upstash Redis in Vercel dashboard:
# Vercel Project > Settings > Integrations > Browse Marketplace > Upstash Redis
# Or create manually at https://console.upstash.com

KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-token-here
